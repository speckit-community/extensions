{"pageProps":{"extension":{"name":"SFSpeckit — Salesforce Spec-Driven Development","id":"sf","description":"Enterprise-Grade Spec-Driven Development (SDD) Framework for Salesforce.","author":"Sumanth Yanamala","version":"1.0.0","download_url":"https://github.com/ysumanth06/spec-kit-sf/archive/refs/tags/v1.0.0.zip","repository":"https://github.com/ysumanth06/spec-kit-sf","homepage":"https://ysumanth06.github.io/spec-kit-sf/","documentation":"https://ysumanth06.github.io/spec-kit-sf/introduction.html","changelog":"https://github.com/ysumanth06/spec-kit-sf/blob/main/CHANGELOG.md","license":"MIT","requires":{"speckit_version":">=0.4.0","tools":[{"name":"sf","version":">=2.0.0","required":true},{"name":"gh","version":">=2.0.0","required":false}]},"provides":{"commands":18,"hooks":2},"tags":["salesforce","enterprise","sdlc","apex","devops"],"verified":false,"downloads":0,"stars":1,"created_at":"2026-04-13T22:11:30Z","updated_at":"2026-04-13T22:11:30Z","releaseVersion":"1.0.0","releasePublishedAt":"2026-04-13T22:19:05Z"},"dependents":[],"readmeContent":"<!DOCTYPE html>\n<html class=\"dark\" lang=\"en\">\n<head>\n    <meta charset=\"utf-8\"/>\n    <meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n    <title>Introduction | SFSpeckit</title>\n    <script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&amp;family=Space+Grotesk:wght@300;400;500;700&amp;family=Fira+Code&amp;display=swap\" rel=\"stylesheet\"/>\n    <link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n    <link rel=\"icon\" type=\"image/png\" href=\"assets/logo.png\"/>\n    <script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    \"colors\": {\n                        \"primary-container\": \"#00e5ff\",\n                        \"on-primary-container\": \"#00626e\",\n                        \"on-error\": \"#690005\",\n                        \"on-tertiary-container\": \"#6f5500\",\n                        \"primary\": \"#c3f5ff\",\n                        \"tertiary-container\": \"#fec931\",\n                        \"secondary-container\": \"#3d4759\",\n                        \"surface-variant\": \"#313540\",\n                        \"on-secondary-fixed\": \"#121c2c\",\n                        \"inverse-on-surface\": \"#2c303b\",\n                        \"inverse-surface\": \"#dfe2f1\",\n                        \"surface-container-lowest\": \"#0a0e18\",\n                        \"surface-container-highest\": \"#313540\",\n                        \"on-secondary\": \"#273141\",\n                        \"outline\": \"#849396\",\n                        \"surface-tint\": \"#00daf3\",\n                        \"primary-fixed-dim\": \"#00daf3\",\n                        \"surface-container-high\": \"#262a35\",\n                        \"tertiary\": \"#ffeac0\",\n                        \"on-tertiary-fixed-variant\": \"#594400\",\n                        \"background\": \"#0f131d\",\n                        \"surface\": \"#0f131d\",\n                        \"secondary-fixed-dim\": \"#bdc7dc\",\n                        \"on-primary\": \"#00363d\",\n                        \"on-primary-fixed\": \"#001f24\",\n                        \"on-tertiary\": \"#3e2e00\",\n                        \"outline-variant\": \"#3b494c\",\n                        \"secondary-fixed\": \"#d9e3f9\",\n                        \"surface-container-low\": \"#171b26\",\n                        \"surface-bright\": \"#353944\",\n                        \"on-secondary-container\": \"#abb5cb\",\n                        \"surface-container\": \"#1c1f2a\",\n                        \"tertiary-fixed-dim\": \"#f3bf26\",\n                        \"on-surface\": \"#dfe2f1\",\n                        \"on-error-container\": \"#ffdad6\",\n                        \"on-tertiary-fixed\": \"#251a00\",\n                        \"on-background\": \"#dfe2f1\",\n                        \"error-container\": \"#93000a\",\n                        \"on-surface-variant\": \"#bac9cc\",\n                        \"error\": \"#ffb4ab\",\n                        \"inverse-primary\": \"#006875\",\n                        \"on-primary-fixed-variant\": \"#004f58\",\n                        \"tertiary-fixed\": \"#ffdf96\",\n                        \"on-secondary-fixed-variant\": \"#3d4759\",\n                        \"primary-fixed\": \"#9cf0ff\",\n                        \"surface-dim\": \"#0f131d\",\n                        \"secondary\": \"#bdc7dc\"\n                    },\n                    \"borderRadius\": {\n                        \"DEFAULT\": \"0.125rem\",\n                        \"lg\": \"0.25rem\",\n                        \"xl\": \"0.5rem\",\n                        \"full\": \"0.75rem\"\n                    },\n                    \"fontFamily\": {\n                        \"headline\": [\"Inter\"],\n                        \"body\": [\"Inter\"],\n                        \"label\": [\"Space Grotesk\"]\n                    }\n                },\n            },\n        }\n    </script>\n    <style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .glass-panel {\n            background: rgba(28, 31, 42, 0.6);\n            backdrop-filter: blur(12px);\n        }\n        .tonal-shift {\n            background: linear-gradient(180deg, rgba(23, 27, 38, 0.5) 0%, rgba(15, 19, 29, 0) 100%);\n        }\n        ::-webkit-scrollbar { width: 4px; }\n        ::-webkit-scrollbar-track { background: #0f131d; }\n        ::-webkit-scrollbar-thumb { background: #313540; border-radius: 10px; }\n    </style>\n</head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container overflow-x-hidden\">\n<!-- TopNavBar -->\n<nav class=\"fixed top-0 w-full z-50 bg-[#0f131d]/80 backdrop-blur-xl shadow-[0_0_20px_rgba(0,229,255,0.05)] border-b border-white/5\">\n    <div class=\"flex items-center justify-between px-6 md:px-12 py-4 w-full\">\n        <div class=\"flex items-center gap-4\">\n            <!-- Mobile Toggle -->\n            <button id=\"sidebar-toggle\" class=\"md:hidden text-cyan-400 p-2 hover:bg-white/5 rounded-lg transition-colors\">\n                <span class=\"material-symbols-outlined font-bold\">menu</span>\n            </button>\n            <a href=\"index.html\" class=\"flex items-center gap-4\">\n                <img alt=\"SFSpeckit Logo\" class=\"w-8 h-8\" src=\"assets/logo.png\"/>\n                <span class=\"text-xl md:text-2xl font-black tracking-tighter text-cyan-400 font-headline uppercase\">SFSpeckit</span>\n            </a>\n            <div class=\"hidden lg:flex gap-6 items-center ml-4\">\n                <a class=\"font-['Inter'] font-bold text-sm tracking-tight text-cyan-400 border-b-2 border-cyan-400 pb-1\" href=\"introduction.html\">Docs</a>\n                <a class=\"font-['Inter'] font-bold text-sm tracking-tight text-slate-400 hover:text-slate-200 transition-colors\" href=\"https://github.com/ysumanth06/spec-kit-sf\" target=\"_blank\">GitHub</a>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-4\">\n            <a href=\"commands.html\" class=\"bg-primary-container text-on-primary-container px-4 md:px-6 py-2 rounded-lg text-xs md:text-sm font-bold hover:bg-cyan-400/90 transition-all shadow-[0_0_15px_rgba(0,229,255,0.2)]\">\n                Get Started\n            </a>\n        </div>\n    </div>\n</nav>\n\n<div class=\"flex min-h-screen pt-16\">\n    <!-- Sidebar -->\n    <div id=\"sidebar-backdrop\" class=\"fixed inset-0 bg-black/60 backdrop-blur-sm z-40 hidden md:hidden\"></div>\n    <aside id=\"sidebar\" class=\"flex flex-col fixed left-0 top-16 h-[calc(100vh-64px)] overflow-y-auto w-64 border-r border-slate-800/50 bg-[#0f131d] z-40 transition-transform duration-300 -translate-x-full md:translate-x-0\">\n        <nav class=\"flex flex-col gap-1 px-2 py-4\">\n            <a class=\"flex items-center gap-3 bg-cyan-400/10 text-cyan-400 border-r-2 border-cyan-400 px-4 py-3 font-bold font-['Space_Grotesk'] text-xs uppercase tracking-widest transition-all\" href=\"introduction.html\">\n                <span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">info</span>\n                <span>Introduction</span>\n            </a>\n            <a class=\"flex items-center gap-3 text-slate-400 px-4 py-3 hover:bg-slate-800/50 transition-all hover:text-cyan-300 hover:translate-x-1 font-['Space_Grotesk'] text-xs uppercase tracking-widest\" href=\"constitution.html\">\n                <span class=\"material-symbols-outlined\">gavel</span>\n                <span>Constitution</span>\n            </a>\n            <a class=\"flex items-center gap-3 text-slate-400 px-4 py-3 hover:bg-slate-800/50 transition-all hover:text-cyan-300 hover:translate-x-1 font-['Space_Grotesk'] text-xs uppercase tracking-widest\" href=\"lifecycle.html\">\n                <span class=\"material-symbols-outlined\">api</span>\n                <span>SDD Lifecycle</span>\n            </a>\n            <a class=\"flex items-center gap-3 text-slate-400 px-4 py-3 hover:bg-slate-800/50 transition-all hover:text-cyan-300 hover:translate-x-1 font-['Space_Grotesk'] text-xs uppercase tracking-widest\" href=\"commands.html\">\n                <span class=\"material-symbols-outlined\">terminal</span>\n                <span>Slash Commands</span>\n            </a>\n            <a class=\"flex items-center gap-3 text-slate-400 px-4 py-3 hover:bg-slate-800/50 transition-all hover:text-cyan-300 hover:translate-x-1 font-['Space_Grotesk'] text-xs uppercase tracking-widest\" href=\"deployment.html\">\n                <span class=\"material-symbols-outlined\">rocket_launch</span>\n                <span>Deployment</span>\n            </a>\n        </nav>\n    </aside>\n\n    <!-- Main Content Canvas -->\n    <main class=\"md:ml-64 flex-1 p-6 md:p-12 lg:p-20 overflow-x-hidden\">\n        <section class=\"max-w-4xl mb-24 relative\">\n            <div class=\"relative z-10\">\n                <h1 class=\"text-4xl md:text-7xl font-black font-headline tracking-tighter text-on-surface mb-6 leading-tight\">\n                    Welcome to <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-primary-container\">SFSpeckit</span>\n                </h1>\n                <p class=\"text-lg md:text-2xl font-label text-slate-400 mb-8 leading-relaxed max-w-2xl font-bold uppercase tracking-wide\">\n                    Better Results. No Hallucinations. Enterprise Grade.\n                </p>\n                <p class=\"text-base md:text-lg text-slate-300 leading-relaxed max-w-3xl mb-6\">\n                    SFSpeckit is a toolkit for Salesforce teams who want to use AI without the risks. Most AI tools \"hallucinate\" or make mistakes because they don't have a plan. SFSpeckit fixes this by enforcing **Spec-Driven Development (SDD)**.\n                </p>\n                <div class=\"bg-primary/5 border border-primary/20 p-6 rounded-2xl mb-8\">\n                    <h3 class=\"text-primary font-bold mb-2 flex items-center gap-2\">\n                        <span class=\"material-symbols-outlined\">psychology</span>\n                        The Problem it Solves\n                    </h3>\n                    <p class=\"text-sm text-slate-400 italic\">\n                        \"In the era of AI-agentic coding, jumping directly into implementation is the fastest way to hit context limits, create hallucinations, and accumulate technical debt.\"\n                    </p>\n                </div>\n            </div>\n        </section>\n\n        <!-- Strategy Grid (Responsive) -->\n        <section class=\"mb-24\">\n            <h2 class=\"text-2xl font-headline font-bold mb-8 flex items-center gap-4 text-white\">\n                The 5 Phases of SDD\n                <span class=\"h-px flex-1 bg-white/5\"></span>\n            </h2>\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-16\">\n                <!-- SPEC -->\n                <div class=\"bg-surface-container-low p-6 rounded-2xl border border-white/5 hover:border-primary/30 transition-all\">\n                    <div class=\"w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4\">\n                        <span class=\"material-symbols-outlined text-primary\">description</span>\n                    </div>\n                    <h3 class=\"font-bold text-lg mb-2 text-white\">1. SPEC</h3>\n                    <p class=\"text-sm text-slate-400\">Define <b>what</b> we are building. Functional requirements and user stories.</p>\n                </div>\n                <!-- PLAN -->\n                <div class=\"bg-surface-container-low p-6 rounded-2xl border border-white/5 hover:border-primary/30 transition-all\">\n                    <div class=\"w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4\">\n                        <span class=\"material-symbols-outlined text-primary\">architecture</span>\n                    </div>\n                    <h3 class=\"font-bold text-lg mb-2 text-white\">2. PLAN</h3>\n                    <p class=\"text-sm text-slate-400\">Define <b>how</b> we build it. Technical blueprints and dependency maps.</p>\n                </div>\n                <!-- BUILD -->\n                <div class=\"bg-surface-container-low p-6 rounded-2xl border border-white/5 hover:border-primary/30 transition-all\">\n                    <div class=\"w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4\">\n                        <span class=\"material-symbols-outlined text-primary\">code</span>\n                    </div>\n                    <h3 class=\"font-bold text-lg mb-2 text-white\">3. BUILD</h3>\n                    <p class=\"text-sm text-slate-400\">The actual coding phase. AI builds logic while following your rules.</p>\n                </div>\n                <!-- TEST -->\n                <div class=\"bg-surface-container-low p-6 rounded-2xl border border-white/5 hover:border-primary/30 transition-all\">\n                    <div class=\"w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4\">\n                        <span class=\"material-symbols-outlined text-primary\">rule</span>\n                    </div>\n                    <h3 class=\"font-bold text-lg mb-2 text-white\">4. TEST</h3>\n                    <p class=\"text-sm text-slate-400\">Verify everything. Automated tests and human sign-offs.</p>\n                </div>\n                <!-- DEPLOY -->\n                <div class=\"bg-surface-container-low p-6 rounded-2xl border border-white/5 hover:border-primary/30 transition-all\">\n                    <div class=\"w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4\">\n                        <span class=\"material-symbols-outlined text-primary\">rocket_launch</span>\n                    </div>\n                    <h3 class=\"font-bold text-lg mb-2 text-white\">5. DEPLOY</h3>\n                    <p class=\"text-sm text-slate-400\">Safe promotion across environments (Dev, QA, UAT, Prod).</p>\n                </div>\n            </div>\n\n            <!-- Prerequisites & Setup -->\n            <div class=\"space-y-12\">\n                <div>\n                    <h2 class=\"text-2xl font-headline font-bold mb-8 flex items-center gap-4 text-white\">\n                        Installation & Setup\n                        <span class=\"h-px flex-1 bg-white/5\"></span>\n                    </h2>\n                    <p class=\"text-slate-400 mb-6 font-bold uppercase text-xs tracking-widest px-4\">Step 1: Install the Extension</p>\n                    <div class=\"bg-black/40 rounded-2xl border border-white/5 p-6 mb-8 font-mono text-sm overflow-x-auto\">\n                        <code class=\"text-cyan-400\">specify extension add sf --from https://github.com/ysumanth06/spec-kit-sf/archive/refs/tags/v1.0.0.zip</code>\n                    </div>\n                    \n                    <p class=\"text-slate-400 mb-6 font-bold uppercase text-xs tracking-widest px-4\">Step 2: Automated Environment Config</p>\n                    <div class=\"bg-black/40 rounded-2xl border border-white/5 p-6 font-mono text-sm overflow-x-auto\">\n                        <code class=\"text-cyan-400\">/speckit.sf.setup</code>\n                    </div>\n                </div>\n\n                <div>\n                    <h2 class=\"text-2xl font-headline font-bold mb-8 flex items-center gap-4 text-white\">\n                        Prerequisites\n                        <span class=\"h-px flex-1 bg-white/5\"></span>\n                    </h2>\n                    <div class=\"overflow-x-auto rounded-xl border border-white/5 bg-surface-container-low\">\n                        <table class=\"w-full text-left\">\n                            <thead class=\"bg-white/5 text-[10px] font-bold uppercase tracking-widest text-slate-500\">\n                                <tr>\n                                    <th class=\"px-6 py-4\">Tool</th>\n                                    <th class=\"px-6 py-4\">Version</th>\n                                    <th class=\"px-6 py-4\">Purpose</th>\n                                </tr>\n                            </thead>\n                            <tbody class=\"divide-y divide-white/5 text-sm text-slate-300\">\n                                <tr>\n                                    <td class=\"px-6 py-4 font-bold text-white\">Spec Kit</td>\n                                    <td class=\"px-6 py-4\">≥ 0.4.0</td>\n                                    <td class=\"px-6 py-4\">Core SDD framework engine.</td>\n                                </tr>\n                                <tr>\n                                    <td class=\"px-6 py-4 font-bold text-white\">Salesforce CLI</td>\n                                    <td class=\"px-6 py-4\">≥ 2.0.0</td>\n                                    <td class=\"px-6 py-4\">Metadata operations & org connectivity.</td>\n                                </tr>\n                                <tr>\n                                    <td class=\"px-6 py-4 font-bold text-white\">SF Code Analyzer</td>\n                                    <td class=\"px-6 py-4\">≥ 5.0.0</td>\n                                    <td class=\"px-6 py-4\">Security & Quality Gates (PMD 7).</td>\n                                </tr>\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            </div>\n        </section>\n    </main>\n</div>\n\n<!-- Footer -->\n<footer class=\"w-full border-t border-white/5 bg-slate-950 p-6 md:p-12 text-on-surface\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 items-center gap-8\">\n        <div class=\"hidden md:block\"></div>\n        <div class=\"flex justify-center gap-6 font-['Space_Grotesk'] text-[10px] tracking-widest font-bold uppercase text-slate-600\">\n            <a class=\"hover:text-cyan-400 transition-colors\" href=\"index.html\">Home</a>\n            <a class=\"hover:text-cyan-400 transition-colors\" href=\"https://github.com/ysumanth06/spec-kit-sf\">GitHub</a>\n            <a class=\"hover:text-cyan-400 transition-colors\" href=\"https://www.linkedin.com/in/ysumanth/\">LinkedIn</a>\n        </div>\n        <div class=\"text-center md:text-right\">\n            <p class=\"font-['Space_Grotesk'] text-[10px] tracking-[0.2em] text-cyan-400 font-bold uppercase mb-2\">SFSpeckit Framework</p>\n            <p class=\"text-[9px] text-slate-500 uppercase tracking-widest font-bold font-['Inter'] hover:text-slate-400 transition-colors\">© 2026 Spec-Driven Development</p>\n        </div>\n    </div>\n</footer>\n\n<script>\n    const toggle = document.getElementById('sidebar-toggle');\n    const sidebar = document.getElementById('sidebar');\n    const backdrop = document.getElementById('sidebar-backdrop');\n\n    toggle.addEventListener('click', () => {\n        sidebar.classList.toggle('-translate-x-full');\n        backdrop.classList.toggle('hidden');\n        document.body.style.overflow = sidebar.classList.contains('-translate-x-full') ? '' : 'hidden';\n    });\n\n    backdrop.addEventListener('click', () => {\n        sidebar.classList.add('-translate-x-full');\n        backdrop.classList.add('hidden');\n        document.body.style.overflow = '';\n    });\n</script>\n</body>\n</html>\n","manifest":{"commands":[{"name":"speckit.sf.setup","file":"commands/setup.md","description":"Automated dependency checker and installer (sf, gh, sf-scanner).","aliases":null},{"name":"speckit.sf.constitution","file":"commands/constitution.md","description":"Establish Salesforce project principles with 9 articles and environmental discovery.","aliases":null},{"name":"speckit.sf.specify","file":"commands/specify.md","description":"Create a Salesforce feature spec with object maps and security model.","aliases":null},{"name":"speckit.sf.clarify","file":"commands/clarify.md","description":"Run the Salesforce gap analysis checklist against the specification.","aliases":null},{"name":"speckit.sf.plan","file":"commands/plan.md","description":"Create a technical plan with force-app structure and blast radius analysis.","aliases":null},{"name":"speckit.sf.stories","file":"commands/stories.md","description":"Generate Jira-ready developer stories with security matrices.","aliases":null},{"name":"speckit.sf.implement","file":"commands/implement.md","description":"Implement a story file with auto-heal loop and scoring gates.","aliases":null},{"name":"speckit.sf.review","file":"commands/review.md","description":"TPO and Architect review of generated stories before Jira creation.","aliases":null},{"name":"speckit.sf.change","file":"commands/change.md","description":"Handle mid-sprint requirement changes with impact analysis.","aliases":null},{"name":"speckit.sf.qa","file":"commands/qa.md","description":"Generate manual test scripts and run automated Apex/Jest tests.","aliases":null},{"name":"speckit.sf.pr","file":"commands/pr.md","description":"Prepare a PR with scoring gates and code review checklist.","aliases":null},{"name":"speckit.sf.verify","file":"commands/verify.md","description":"Generate formal Verification Evidence documents with coverage metrics.","aliases":null},{"name":"speckit.sf.deploy","file":"commands/deploy.md","description":"Promote Salesforce code across environments (Dev to QA to UAT to Prod).","aliases":null},{"name":"speckit.sf.score","file":"commands/score.md","description":"555-point quality scoring dashboard across all stories in a feature.","aliases":null},{"name":"speckit.sf.hotfix","file":"commands/hotfix.md","description":"Emergency production bug fix workflow with fast-track deployment.","aliases":null},{"name":"speckit.sf.regression","file":"commands/regression.md","description":"Run full regression tests across all stories in a feature.","aliases":null},{"name":"speckit.sf.release-notes","file":"commands/release-notes.md","description":"Auto-generate release notes from completed stories and test results.","aliases":null},{"name":"speckit.sf.uat","file":"commands/uat.md","description":"Generate UAT scripts and manage business sign-offs.","aliases":null}],"hooks":[{"event":"after_tasks","command":"speckit.sf.review","optional":true,"prompt":"Run Architect review of generated stories?","description":"Validates story dependency graph, deployment order, merge conflict risks"},{"event":"after_implement","command":"speckit.sf.verify","optional":true,"prompt":"Generate verification evidence for the completed story?","description":"Runs Apex/LWC tests and generates formal Verification Evidence document"}],"config":[{"name":"sf-config.yml","template":"sf-config.template.yml","description":"Salesforce project configuration (org aliases, scoring thresholds)","required":false}],"requiredCommands":["speckit.tasks"]}},"__N_SSG":true}